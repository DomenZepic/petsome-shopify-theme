{% render 'kaching-custom-display', block: block, section: section %}

{% schema %}
{
  "name": "Kaching custom display",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "IMPORTANT NOTES"
    },
    {
      "type": "paragraph",
      "content": "Replaces Kaching Bundles' own widget UI with our custom tiles, while keeping Kaching's pricing/discount/cart/gift logic. Requires a Kaching Bundles app block to already be present on this page (it gets hidden automatically) and a deal configured for this product."
    },
    {
      "type": "richtext",
      "id": "disclaimer_text",
      "label": "Disclaimer text",
      "info": "Shown below the package tiles. Leave blank to hide.",
      "default": "<p>*First changes are visible in 2-3 weeks. For best results we recommend 2-3 months of use.</p>"
    },
    {
      "type": "text",
      "id": "gifts_heading",
      "label": "Gifts heading override",
      "info": "Reads gift unlock tiers from the same Kaching deal's freeGifts field per quantity tier. Leave blank to use the translatable default heading (editable per language in Settings > Languages > Theme). Use \"Hide gifts heading\" below to hide it entirely."
    },
    {
      "type": "checkbox",
      "id": "hide_gifts_heading",
      "label": "Hide gifts heading",
      "default": false
    },
    {
      "type": "header",
      "content": "Tier colors"
    },
    {
      "type": "paragraph",
      "content": "Choose the color of the label strip above each tier by position (1st = smallest quantity, last = largest). Label text is pulled from Kaching. 'None' hides the strip for that tier."
    },
    {
      "type": "select",
      "id": "tier_1_style",
      "label": "Tier 1 color",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "recommended", "label": "Beige" },
        { "value": "best", "label": "Black" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "tier_2_style",
      "label": "Tier 2 color",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "recommended", "label": "Beige" },
        { "value": "best", "label": "Black" }
      ],
      "default": "recommended"
    },
    {
      "type": "select",
      "id": "tier_3_style",
      "label": "Tier 3 color",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "recommended", "label": "Beige" },
        { "value": "best", "label": "Black" }
      ],
      "default": "best"
    },
    {
      "type": "select",
      "id": "tier_4_style",
      "label": "Tier 4 color",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "recommended", "label": "Beige" },
        { "value": "best", "label": "Black" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "paragraph",
      "content": "If the product has a \"Product accent color\" / \"Product secondary color\" metafield set, that value is used instead of the colors below - these only apply as a fallback when the metafield is blank."
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (fallback)",
      "info": "Used for the savings badge gradient and the \"best savings\" tile/badge.",
      "default": "#f8aaa7"
    },
    {
      "type": "color",
      "id": "accent_color_dark",
      "label": "Accent color dark / gradient end (fallback)",
      "info": "Used as the darker end of the savings badge gradient. Same metafield-first pattern: set \"Product accent color (gradient end)\" on the product to control this precisely; if left blank everywhere, it's auto-darkened from the accent color.",
      "default": "#f47671"
    },
    {
      "type": "color",
      "id": "secondary_color",
      "label": "Secondary color (fallback)",
      "info": "Used for the \"recommended\" tile/badge, the selected-tile highlight, and the gifts panel.",
      "default": "#e8d6c5"
    },
    {
      "type": "color",
      "id": "light_text_color",
      "label": "Light text color",
      "info": "Used for text on top of the accent-colored savings badge and \"best savings\" label.",
      "default": "#FAF9F6"
    },
    {
      "type": "header",
      "content": "Dosage / supply math"
    },
    {
      "type": "select",
      "id": "product_type",
      "label": "Product type",
      "info": "Determines whether dosage captions are worded/measured in capsules or grams. Supply math is identical either way.",
      "options": [
        { "value": "capsules", "label": "Capsules" },
        { "value": "powder", "label": "Powder" }
      ],
      "default": "capsules"
    },
    {
      "type": "number",
      "id": "capsules_per_package",
      "label": "Capsules per package",
      "info": "0 disables the dosage/supply captions.",
      "default": 90,
      "visible_if": "{{ block.settings.product_type == 'capsules' }}"
    },
    {
      "type": "text",
      "id": "capsules_per_day_by_size",
      "label": "Capsules per day, by size option value",
      "info": "One number per size option value, comma-separated, in the same order as the size option's values.",
      "default": "1, 2, 3",
      "visible_if": "{{ block.settings.product_type == 'capsules' }}"
    },
    {
      "type": "number",
      "id": "grams_per_package",
      "label": "Grams per package",
      "info": "0 disables the dosage/supply captions.",
      "default": 90,
      "visible_if": "{{ block.settings.product_type == 'powder' }}"
    },
    {
      "type": "text",
      "id": "grams_per_day_by_size",
      "label": "Grams per day, by size option value",
      "info": "One number per size option value, comma-separated, in the same order as the size option's values.",
      "default": "1, 2, 3",
      "visible_if": "{{ block.settings.product_type == 'powder' }}"
    },
    {
      "type": "header",
      "content": "Margins"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "Kaching custom display",
      "category": "Product basics"
    }
  ]
}
{% endschema %}
