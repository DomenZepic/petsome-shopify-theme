{% render 'kaching-custom-display', block: block, section: section %}

{% schema %}
{
  "name": "Kaching custom display",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "IMPORTANT NOTES"
    },
    {
      "type": "paragraph",
      "content": "Replaces Kaching Bundles' own widget UI with our custom tiles, while keeping Kaching's pricing/discount/gift logic. Requires a Kaching Bundles app block to already be present on this page (it gets hidden automatically) and a deal configured for this product."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose your package"
    },
    {
      "type": "text",
      "id": "gifts_heading",
      "label": "Gifts heading",
      "info": "Reads gift unlock tiers from the same Kaching deal's freeGifts field per quantity tier. Leave blank to hide the heading.",
      "default": "Brezplačna darila ob nakupu"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "paragraph",
      "content": "If the product has a \"Product accent color\" / \"Product secondary color\" metafield set, that value is used instead of the colors below - these only apply as a fallback when the metafield is blank."
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (fallback)",
      "info": "Used for the selected tile border, the \"best savings\" badge, and the gifts panel highlight.",
      "default": "#f8aaa7"
    },
    {
      "type": "color",
      "id": "accent_color_dark",
      "label": "Accent color dark / gradient end (fallback)",
      "info": "Used as the darker end of the \"best savings\" badge gradient. Same metafield-first pattern: set \"Product accent color (gradient end)\" on the product to control this precisely; if left blank everywhere, it's auto-darkened from the accent color.",
      "default": "#f47671"
    },
    {
      "type": "color",
      "id": "secondary_color",
      "label": "Secondary color (fallback)",
      "info": "Used for the \"recommended\" tile/badge and the gifts panel heading.",
      "default": "#e8d6c5"
    },
    {
      "type": "header",
      "content": "Dosage / supply math"
    },
    {
      "type": "number",
      "id": "capsules_per_package",
      "label": "Capsules per package",
      "info": "0 disables the dosage/supply captions.",
      "default": 90
    },
    {
      "type": "text",
      "id": "capsules_per_day_by_size",
      "label": "Capsules per day, by size option value",
      "info": "One number per size option value, comma-separated, in the same order as the size option's values.",
      "default": "1, 2, 3"
    },
    {
      "type": "header",
      "content": "Margins"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "Kaching custom display",
      "category": "Product basics"
    }
  ]
}
{% endschema %}
