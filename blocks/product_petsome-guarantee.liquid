<style>
  #petsome-guarantee-{{ block.id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    border: 1px dashed {{ block.settings.border_color }};
    border-radius: 12px;
    background-color: {{ block.settings.background_color }};
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
  }

  #petsome-guarantee-{{ block.id }} .petsome-guarantee__image {
    flex-shrink: 0;
    width: 73px;
    height: 70px;
    object-fit: contain;
  }

  #petsome-guarantee-{{ block.id }} .petsome-guarantee__text {
    flex: 1 0 0;
    min-width: 0;
    font-size: 1.4rem;
    line-height: 1.3;
    color: #3b2f2f;
  }

  #petsome-guarantee-{{ block.id }} .petsome-guarantee__text p {
    margin: 0;
  }
</style>

<div
  id="petsome-guarantee-{{ block.id }}"
  class="petsome-guarantee quick-add-hidden {{ block.settings.visibility }}"
  {{ block.shopify_attributes }}
>
  {%- if block.settings.badge_image != blank -%}
    <img
      class="petsome-guarantee__image"
      src="{{ block.settings.badge_image | image_url: width: 146 }}"
      alt="{{ block.settings.badge_image.alt | default: '' }}"
      width="73"
      height="70"
      loading="lazy"
    >
  {%- endif -%}
  {%- if block.settings.text != blank -%}
    <div class="petsome-guarantee__text">{{ block.settings.text }}</div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Petsome: Guarantee",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "visibility",
      "label": "Display on",
      "options": [
        { "value": "desktop-hidden", "label": "Mobile only" },
        { "value": "mobile-hidden", "label": "Desktop only" },
        { "value": "always-display", "label": "All devices" }
      ],
      "default": "always-display"
    },
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Badge image",
      "info": "Recommended 146 × 140px."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Pri Petsome želimo, da vsak MobiMix ljubljenčku izboljša gibanje. Če ste v dvomih, ali je ta izdelek za vašega ljubljenčka - ni panike. Vaše naročilo je zaščiteno z 60-dnevno garancijo vračila denarja. Brez slabe vesti.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#E8D6C5"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#b6a87c"
    },
    {
      "type": "header",
      "content": "Margins"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Petsome: Guarantee"
    }
  ]
}
{% endschema %}
