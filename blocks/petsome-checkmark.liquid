{% comment %}
  Petsome: Checkmark - a single checkmark + text line, used as a
  repeatable child block inside "Petsome: Checkmarks". Styling is
  provided by the parent block's <style> rules.
{% endcomment %}
{%- if block.settings.text != blank -%}
  <div class="petsome-checkmark" {{ block.shopify_attributes }}>
    <span class="petsome-checkmark__icon">{% render 'material-icon', icon: 'check_circle', filled: true %}</span>
    <span class="petsome-checkmark__text">{{ block.settings.text }}</span>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Checkmark",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Benefit text"
    }
  ]
}
{% endschema %}
