{% comment %}
  Petsome Ld: Hero - landing-page hero (the "Ld" family). Full-width background
  image with separate desktop/mobile images. Content (rating badge, heading,
  subline, CTA) is left-aligned on desktop, centred on mobile. Uses the BODY
  font everywhere so the whole landing page reads as one consistent style.
{% endcomment %}
<style>
  #petsome-ld-hero-{{ section.id }} {
    position: relative;
    overflow: hidden;
    min-height: {{ section.settings.min_height }}px;
    display: flex;
    align-items: center;
    background-color: {{ section.settings.background_color }};
    font-family: var(--font-body-family);
  }

  #petsome-ld-hero-{{ section.id }} * {
    font-family: var(--font-body-family);
  }

  #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__bg--mobile {
    display: none;
  }

  #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__inner {
    position: relative;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px var(--petsome-padding-x) {{ section.settings.padding_bottom }}px;
  }

  #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__content {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 560px;
  }

  #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__text {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__rating {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__rating-img {
    height: 22px;
    width: auto;
  }

  #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__rating-text {
    font-size: 1.6rem;
    font-weight: 500;
    color: {{ section.settings.text_color }};
    line-height: 1.3;
  }

  #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__heading {
    font-weight: 800;
    font-size: 4.4rem;
    line-height: 1.15;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__heading p {
    margin: 0;
  }

  #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__subline {
    font-size: 1.7rem;
    line-height: 1.5;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__subline p {
    margin: 0;
  }

  #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.5;
    padding: 16px 32px;
    border-radius: 8px;
    text-decoration: none;
    align-self: flex-start;
  }

  #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__cta .material-icon {
    font-size: 2rem;
  }

  @media screen and (max-width: 749px) {
    #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__bg--desktop {
      display: none;
    }

    #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__bg--mobile {
      display: block;
    }

    #petsome-ld-hero-{{ section.id }} {
      align-items: flex-start;
    }

    #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__inner {
      padding-top: 40px;
      padding-bottom: 40px;
    }

    #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__content {
      max-width: 100%;
      align-items: center;
      text-align: center;
    }

    #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__rating {
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }

    #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__heading {
      font-size: 3.2rem;
    }

    #petsome-ld-hero-{{ section.id }} .petsome-ld-hero__cta {
      align-self: stretch;
      justify-content: center;
    }
  }
</style>

<div id="petsome-ld-hero-{{ section.id }}" class="petsome-ld-hero">
  {%- if section.settings.desktop_image != blank -%}
    <img
      class="petsome-ld-hero__bg petsome-ld-hero__bg--desktop"
      src="{{ section.settings.desktop_image | image_url: width: 2400 }}"
      alt=""
      width="{{ section.settings.desktop_image.width }}"
      height="{{ section.settings.desktop_image.height }}"
      loading="eager"
      fetchpriority="high"
    >
  {%- endif -%}

  {%- if section.settings.mobile_image != blank -%}
    <img
      class="petsome-ld-hero__bg petsome-ld-hero__bg--mobile"
      src="{{ section.settings.mobile_image | image_url: width: 1200 }}"
      alt=""
      width="{{ section.settings.mobile_image.width }}"
      height="{{ section.settings.mobile_image.height }}"
      loading="eager"
      fetchpriority="high"
    >
  {%- elsif section.settings.desktop_image != blank -%}
    <img
      class="petsome-ld-hero__bg petsome-ld-hero__bg--mobile"
      src="{{ section.settings.desktop_image | image_url: width: 1200 }}"
      alt=""
      width="{{ section.settings.desktop_image.width }}"
      height="{{ section.settings.desktop_image.height }}"
      loading="eager"
      fetchpriority="high"
    >
  {%- endif -%}

  <div class="petsome-ld-hero__inner">
    <div class="petsome-ld-hero__content">
      <div class="petsome-ld-hero__text">
        {%- if section.settings.rating_image != blank or section.settings.rating_text != blank -%}
          <div class="petsome-ld-hero__rating">
            {%- if section.settings.rating_image != blank -%}
              <img
                class="petsome-ld-hero__rating-img"
                src="{{ section.settings.rating_image | image_url: height: 44 }}"
                alt=""
                width="{{ section.settings.rating_image.width }}"
                height="{{ section.settings.rating_image.height }}"
                loading="lazy"
              >
            {%- endif -%}
            {%- if section.settings.rating_text != blank -%}
              <span class="petsome-ld-hero__rating-text">{{ section.settings.rating_text }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <div class="petsome-ld-hero__heading">{{ section.settings.heading }}</div>
        {%- endif -%}
        {%- if section.settings.subline != blank -%}
          <div class="petsome-ld-hero__subline">{{ section.settings.subline }}</div>
        {%- endif -%}
      </div>
      {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
        <a href="{{ section.settings.cta_url }}" class="petsome-ld-hero__cta">
          {{ section.settings.cta_label }}
          {% render 'material-icon', icon: 'arrow_forward' %}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Petsome Ld: Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image",
      "info": "Recommended 2400 × 1500px."
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Optional — falls back to the desktop image if left blank. Recommended 750 × 900px."
    },
    {
      "type": "header",
      "content": "Rating badge"
    },
    {
      "type": "image_picker",
      "id": "rating_image",
      "label": "Rating image",
      "info": "E.g. a Trustpilot or star-rating graphic exported as PNG/WebP."
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating text",
      "default": "Trusted by 2,000+ dog owners across Europe"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>6 reasons your dog's body will love it</p>"
    },
    {
      "type": "richtext",
      "id": "subline",
      "label": "Subline",
      "default": "<p>One daily scoop that supports joints, digestion, coat and calm — not six different supplements.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "See the offer"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 520
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fallback background",
      "info": "Shown while the image loads or if no image is set.",
      "default": "#E8D6C5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#3B2F2F"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#3B2F2F"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Petsome Ld: Hero"
    }
  ]
}
{% endschema %}
