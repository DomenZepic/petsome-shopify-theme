{% comment %}
  Petsome: Home – Products. Heading + subline above a set of product
  cards. Each card is a block with a product picker so the merchant
  chooses exactly which products appear and in what order.
  Desktop: equal-width columns. Mobile: 2-column grid.
{% endcomment %}
<style>
  #petsome-home-products-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #petsome-home-products-{{ section.id }} p {
    margin: 0;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-products__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--petsome-padding-x);
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: center;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-products__header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-products__heading {
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: var(--petsome-heading-size);
    color: rgb(var(--color-foreground));
    margin: 0;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-products__heading p {
    margin: 0;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-products__subline {
    font-size: 1.6rem;
    line-height: 1.5;
    color: rgb(var(--color-foreground));
    margin: 0;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-products__subline p {
    margin: 0;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-products__grid {
    display: flex;
    gap: 32px;
    align-items: flex-start;
    width: 100%;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-product {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-product__image-link {
    display: block;
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    overflow: hidden;
    background-color: #f0e8e0;
    width: 100%;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-product__image-link img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-product__image-link:hover img {
    transform: scale(1.03);
  }

  #petsome-home-products-{{ section.id }} .petsome-home-product__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-product__title {
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: 2.4rem;
    line-height: 1.3;
    color: rgb(var(--color-foreground));
    margin: 0;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-product__description {
    font-size: 1.6rem;
    line-height: 1.5;
    color: rgb(var(--color-foreground));
    margin: 0;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-product__cta {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background-color: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.5;
    padding: 8px 24px;
    border-radius: 8px;
    text-decoration: none;
    align-self: flex-start;
  }

  #petsome-home-products-{{ section.id }} .petsome-home-product__cta .material-icon {
    font-size: 2rem;
  }

  @media screen and (max-width: 749px) {
    #petsome-home-products-{{ section.id }} .petsome-home-products__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    #petsome-home-products-{{ section.id }} .petsome-home-product__title {
      font-size: 1.8rem;
    }

    #petsome-home-products-{{ section.id }} .petsome-home-product__description {
      font-size: 1.4rem;
    }

    #petsome-home-products-{{ section.id }} .petsome-home-product__cta {
      font-size: 1.4rem;
      padding: 8px 16px;
    }
  }
</style>

<div id="petsome-home-products-{{ section.id }}" class="petsome-home-products">
  <div class="petsome-home-products__inner">
    {%- if section.settings.heading != blank or section.settings.subline != blank -%}
      <div class="petsome-home-products__header">
        {%- if section.settings.heading != blank -%}
          <div class="petsome-home-products__heading">{{ section.settings.heading }}</div>
        {%- endif -%}
        {%- if section.settings.subline != blank -%}
          <div class="petsome-home-products__subline">{{ section.settings.subline }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="petsome-home-products__grid">
        {%- for block in section.blocks -%}
          {%- assign product_item = block.settings.product -%}
          {%- if product_item != blank -%}
            {%- assign card_description = block.settings.custom_description -%}
            {%- if card_description == blank -%}
              {%- assign card_description = product_item.metafields.descriptors.subtitle.value -%}
            {%- endif -%}
            <div class="petsome-home-product" {{ block.shopify_attributes }}>
              <a href="{{ product_item.url }}" class="petsome-home-product__image-link" aria-label="{{ product_item.title | escape }}">
                {%- if product_item.featured_image != blank -%}
                  <img
                    src="{{ product_item.featured_image | image_url: width: 800 }}"
                    alt="{{ product_item.featured_image.alt | default: product_item.title | escape }}"
                    width="{{ product_item.featured_image.width }}"
                    height="{{ product_item.featured_image.height }}"
                    loading="lazy"
                  >
                {%- endif -%}
              </a>
              <div class="petsome-home-product__info">
                <p class="petsome-home-product__title">{{ product_item.title }}</p>
                {%- if card_description != blank -%}
                  <p class="petsome-home-product__description">{{ card_description }}</p>
                {%- endif -%}
              </div>
              <a href="{{ product_item.url }}" class="petsome-home-product__cta">
                {{ block.settings.cta_label | default: 'Razišči' }}
                {% render 'material-icon', icon: 'arrow_forward' %}
              </a>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Petsome: Home products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Naše rešitve za zdravje vašega psa</p>"
    },
    {
      "type": "richtext",
      "id": "subline",
      "label": "Subline",
      "default": "<p>Tri ciljne formule. En celostni pristop k zdravju psa.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FAF9F6"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "custom_description",
          "label": "Description",
          "info": "Overrides the product's subtitle metafield. Leave blank to use the product metafield value."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button label",
          "default": "Razišči"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Petsome: Home products",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
