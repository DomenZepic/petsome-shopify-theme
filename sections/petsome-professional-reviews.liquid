{% comment %}
  Petsome: Expert reviews - a heading above a single-review-at-a-
  time carousel sourced from the product's "Professional reviews"
  metafield (a list of "professional_review" metaobjects: image,
  author, role/title, star rating, body), with prev/next controls.
  Image sits beside the content on desktop, stacks above it on
  mobile. Generic/reusable across any product - nothing hardcoded.
{% endcomment %}
{%- liquid
  assign reviews = product.metafields.custom.professional_reviews.value
-%}
<style>
  #petsome-professional-reviews-{{ section.id }} {
    --ppr-star: {{ section.settings.star_color }};
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #petsome-professional-reviews-{{ section.id }} p {
    margin: 0;
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-reviews__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--petsome-padding-x);
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-reviews__heading {
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: var(--petsome-heading-size);
    color: rgb(var(--color-foreground));
    text-align: center;
    margin: 0;
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-reviews__row {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-reviews__nav-button {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: none;
    background-color: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-reviews__nav-button .material-icon {
    font-size: 2.8rem;
    color: rgb(var(--color-foreground));
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-reviews__card-wrapper {
    flex: 1 0 0;
    min-width: 0;
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-review {
    display: none;
    background-color: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    max-height: 350px;
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-review.is-active {
    display: flex;
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-review__image-wrapper {
    flex: 1 0 0;
    min-width: 0;
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-review__image-wrapper img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-review__content {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px;
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-review__stars {
    display: flex;
    gap: 5px;
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-review__stars .material-icon {
    font-size: 1.4rem;
    color: var(--ppr-star);
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-review__author {
    font-weight: 700;
    font-size: 1.6rem;
    line-height: 1.5;
    color: rgb(var(--color-foreground));
    margin: 0;
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-review__body {
    font-size: 1.6rem;
    line-height: 1.5;
    color: rgb(var(--color-foreground));
    margin: 0;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: {{ section.settings.max_lines }};
    overflow: hidden;
  }

  #petsome-professional-reviews-{{ section.id }} .petsome-professional-review__read-more {
    align-self: flex-start;
    background: none;
    border: none;
    padding: 0;
    font-size: 1.6rem;
    font-weight: 700;
    text-decoration: underline;
    color: rgb(var(--color-foreground));
    cursor: pointer;
  }

  @media screen and (max-width: 749px) {
    #petsome-professional-reviews-{{ section.id }} .petsome-professional-review {
      flex-direction: column;
    }

    #petsome-professional-reviews-{{ section.id }} .petsome-professional-review__image-wrapper {
      flex: none;
      width: 100%;
      aspect-ratio: 4 / 3;
    }
  }

  #petsome-professional-reviews-modal-{{ section.id }} {
    --ppr-star: {{ section.settings.star_color }};
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    align-items: center;
    justify-content: center;
    padding: var(--petsome-padding-x);
  }

  #petsome-professional-reviews-modal-{{ section.id }} p {
    margin: 0;
  }

  #petsome-professional-reviews-modal-{{ section.id }}.is-open {
    display: flex;
  }

  #petsome-professional-reviews-modal-{{ section.id }} .petsome-professional-reviews__modal-backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.65);
  }

  #petsome-professional-reviews-modal-{{ section.id }} .petsome-professional-reviews__modal-card {
    position: relative;
    background-color: #ffffff;
    border: 1px solid #e8d6c5;
    border-radius: 16px;
    max-width: 560px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: 0 8px 30px 0 rgba(0, 0, 0, 0.15);
  }

  #petsome-professional-reviews-modal-{{ section.id }} .petsome-professional-reviews__modal-close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background-color: color-mix(in srgb, #e8d6c5 20%, white);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
  }

  #petsome-professional-reviews-modal-{{ section.id }} .petsome-professional-reviews__modal-close .material-icon {
    font-size: 2rem;
    color: rgb(var(--color-foreground));
  }

  #petsome-professional-reviews-modal-{{ section.id }} .petsome-professional-reviews__modal-image-wrapper {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 12px;
    overflow: hidden;
  }

  #petsome-professional-reviews-modal-{{ section.id }} .petsome-professional-reviews__modal-image-wrapper img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #petsome-professional-reviews-modal-{{ section.id }} .petsome-professional-reviews__modal-stars {
    display: flex;
    gap: 5px;
  }

  #petsome-professional-reviews-modal-{{ section.id }} .petsome-professional-reviews__modal-stars .material-icon {
    font-size: 1.4rem;
    color: var(--ppr-star);
  }

  #petsome-professional-reviews-modal-{{ section.id }} .petsome-professional-reviews__modal-author {
    font-weight: 700;
    font-size: 1.8rem;
    line-height: 1.4;
    color: rgb(var(--color-foreground));
  }

  #petsome-professional-reviews-modal-{{ section.id }} .petsome-professional-reviews__modal-body {
    font-size: 1.5rem;
    line-height: 1.5;
    color: rgb(var(--color-foreground));
    white-space: pre-line;
  }
</style>

{%- if reviews.size > 0 -%}
  <div id="petsome-professional-reviews-{{ section.id }}" class="petsome-professional-reviews">
    <div class="petsome-professional-reviews__inner">
      {%- if section.settings.heading != blank -%}
        <div class="petsome-professional-reviews__heading">{{ section.settings.heading }}</div>
      {%- endif -%}

      <div class="petsome-professional-reviews__row">
        {%- if reviews.size > 1 -%}
          <button type="button" class="petsome-professional-reviews__nav-button" data-petsome-pr-prev aria-label="Previous review">
            {% render 'material-icon', icon: 'chevron_left' %}
          </button>
        {%- endif -%}

        <div class="petsome-professional-reviews__card-wrapper">
          {%- for review in reviews -%}
            <div class="petsome-professional-review{% if forloop.first %} is-active{% endif %}" data-petsome-pr-card>
              <div class="petsome-professional-review__image-wrapper">
                {%- if review.image.value != blank -%}
                  <img
                    src="{{ review.image.value | image_url: width: 800 }}"
                    alt="{{ review.author.value | escape }}"
                    width="{{ review.image.value.width }}"
                    height="{{ review.image.value.height }}"
                    loading="lazy"
                  >
                {%- endif -%}
              </div>
              <div class="petsome-professional-review__content">
                {%- if review.rating.value != blank -%}
                  <div class="petsome-professional-review__stars">
                    {%- for i in (1..5) -%}
                      {%- assign is_filled = false -%}
                      {%- if i <= review.rating.value -%}
                        {%- assign is_filled = true -%}
                      {%- endif -%}
                      {% render 'material-icon', icon: 'star', filled: is_filled %}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
                <p class="petsome-professional-review__author">
                  {{ review.author.value }}{% if review.role.value != blank %}, {{ review.role.value }}{% endif %}
                </p>
                {%- if review.body.value != blank -%}
                  <p class="petsome-professional-review__body">{{ review.body.value }}</p>
                  {%- if review.body.value.size > 220 -%}
                    <button
                      type="button"
                      class="petsome-professional-review__read-more"
                      data-petsome-pr-read-more
                      data-name="{{ review.author.value | escape }}{% if review.role.value != blank %}, {{ review.role.value | escape }}{% endif %}"
                      data-rating="{{ review.rating.value }}"
                      data-body="{{ review.body.value | escape }}"
                      data-image="{{ review.image.value | image_url: width: 800 }}"
                    >
                      {{ section.settings.read_more_label }}
                    </button>
                  {%- endif -%}
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- if reviews.size > 1 -%}
          <button type="button" class="petsome-professional-reviews__nav-button" data-petsome-pr-next aria-label="Next review">
            {% render 'material-icon', icon: 'chevron_right' %}
          </button>
        {%- endif -%}
      </div>
    </div>

    <div id="petsome-professional-reviews-modal-{{ section.id }}" data-petsome-pr-modal>
      <div class="petsome-professional-reviews__modal-backdrop" data-petsome-pr-modal-close></div>
      <div class="petsome-professional-reviews__modal-card">
        <button type="button" class="petsome-professional-reviews__modal-close" data-petsome-pr-modal-close aria-label="Close">
          {% render 'material-icon', icon: 'close' %}
        </button>
        <div class="petsome-professional-reviews__modal-image-wrapper" data-petsome-pr-modal-image-wrapper>
          <img data-petsome-pr-modal-image src="" alt="">
        </div>
        <div class="petsome-professional-reviews__modal-stars" data-petsome-pr-modal-stars></div>
        <p class="petsome-professional-reviews__modal-author" data-petsome-pr-modal-author></p>
        <p class="petsome-professional-reviews__modal-body" data-petsome-pr-modal-body></p>
      </div>
    </div>
  </div>

  <script>
    (function () {
      var root = document.getElementById('petsome-professional-reviews-{{ section.id }}');
      if (!root) return;

      var cards = Array.prototype.slice.call(root.querySelectorAll('[data-petsome-pr-card]'));
      var prevButton = root.querySelector('[data-petsome-pr-prev]');
      var nextButton = root.querySelector('[data-petsome-pr-next]');
      var activeIndex = 0;

      function showCard(index) {
        cards[activeIndex].classList.remove('is-active');
        activeIndex = (index + cards.length) % cards.length;
        cards[activeIndex].classList.add('is-active');
      }

      if (prevButton) {
        prevButton.addEventListener('click', function () {
          showCard(activeIndex - 1);
        });
      }

      if (nextButton) {
        nextButton.addEventListener('click', function () {
          showCard(activeIndex + 1);
        });
      }

      var modal = root.querySelector('[data-petsome-pr-modal]');
      document.body.appendChild(modal);
      var modalImageWrapper = modal.querySelector('[data-petsome-pr-modal-image-wrapper]');
      var modalImage = modal.querySelector('[data-petsome-pr-modal-image]');
      var modalStars = modal.querySelector('[data-petsome-pr-modal-stars]');
      var modalAuthor = modal.querySelector('[data-petsome-pr-modal-author]');
      var modalBody = modal.querySelector('[data-petsome-pr-modal-body]');

      function openModal(trigger) {
        var image = trigger.getAttribute('data-image') || '';
        modalImage.src = image;
        modalImageWrapper.style.display = image ? '' : 'none';
        var rating = parseInt(trigger.getAttribute('data-rating'), 10) || 0;
        modalStars.innerHTML = '';
        for (var i = 1; i <= 5; i++) {
          var star = document.createElement('span');
          star.className = 'material-icon material-symbols-outlined' + (i <= rating ? ' filled' : '');
          star.textContent = 'star';
          modalStars.appendChild(star);
        }
        modalAuthor.textContent = trigger.getAttribute('data-name') || '';
        modalBody.textContent = trigger.getAttribute('data-body') || '';
        modal.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }

      function closeModal() {
        modal.classList.remove('is-open');
        document.body.style.overflow = '';
      }

      root.querySelectorAll('[data-petsome-pr-read-more]').forEach(function (trigger) {
        trigger.addEventListener('click', function () {
          openModal(trigger);
        });
      });

      modal.querySelectorAll('[data-petsome-pr-modal-close]').forEach(function (closer) {
        closer.addEventListener('click', closeModal);
      });

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') closeModal();
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Petsome: Expert reviews",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Trusted by professionals and pet owners</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#FAF9F6"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star rating color",
      "default": "#FFCC00"
    },
    {
      "type": "header",
      "content": "Review text"
    },
    {
      "type": "range",
      "id": "max_lines",
      "label": "Max lines before truncating",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "read_more_label",
      "label": "\"Read more\" label",
      "default": "Preberi več"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Petsome: Expert reviews"
    }
  ]
}
{% endschema %}
