{% comment %}
  Petsome: Rotating logos - an infinitely, seamlessly looping
  horizontal strip of repeatable logo images (e.g. vet clinics,
  certifications, press mentions). Same looping technique as
  Petsome: Rotating bullets, but for images instead of text.
  Generic/reusable across any product.
{% endcomment %}
{%- style -%}
  #petsome-rotating-logos-{{ section.id }} {
    --prl-bg: {{ section.settings.background_color }};
    --prl-gap: {{ section.settings.item_spacing }}px;
    --prl-height: {{ section.settings.logo_height }}px;
    --prl-speed: {{ section.settings.speed }}s;
    --prl-direction: {% if section.settings.direction == 'right' %}reverse{% else %}normal{% endif %};
    background-color: var(--prl-bg);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #petsome-rotating-logos-{{ section.id }} .petsome-rotating-logos__viewport {
    overflow: hidden;
    width: 100%;
  }

  #petsome-rotating-logos-{{ section.id }} .petsome-rotating-logos__track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: petsome-rotating-logos-scroll var(--prl-speed) linear infinite;
    animation-direction: var(--prl-direction);
  }

  {% if section.settings.pause_on_hover %}
    #petsome-rotating-logos-{{ section.id }} .petsome-rotating-logos__track:hover {
      animation-play-state: paused;
    }
  {% endif %}

  #petsome-rotating-logos-{{ section.id }} .petsome-rotating-logos__set {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  #petsome-rotating-logos-{{ section.id }} .petsome-rotating-logos__item {
    height: var(--prl-height);
    width: auto;
    object-fit: contain;
    margin-right: var(--prl-gap);
  }

  @keyframes petsome-rotating-logos-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #petsome-rotating-logos-{{ section.id }} .petsome-rotating-logos__track {
      animation: none;
    }
  }
{%- endstyle -%}

{%- if section.blocks.size > 0 -%}
  <div id="petsome-rotating-logos-{{ section.id }}" class="petsome-rotating-logos">
    <div class="petsome-rotating-logos__viewport">
      <div class="petsome-rotating-logos__track">
        {%- for i in (1..2) -%}
          <div class="petsome-rotating-logos__set" aria-hidden="{% if i == 2 %}true{% else %}false{% endif %}">
            {%- for block in section.blocks -%}
              {%- if block.settings.image != blank -%}
                <img
                  class="petsome-rotating-logos__item"
                  src="{{ block.settings.image | image_url: height: 200 }}"
                  alt="{{ block.settings.image.alt | default: block.settings.label | escape }}"
                  loading="lazy"
                  {{ block.shopify_attributes }}
                >
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Petsome: Rotating logos",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Animation duration (seconds per loop)",
      "min": 10,
      "max": 120,
      "step": 5,
      "unit": "s",
      "default": 30
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FAF9F6"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 70
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Spacing between logos",
      "min": 8,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (for alt text)",
          "info": "Used as the image's alt text if the image itself has none set."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Petsome: Rotating logos",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
