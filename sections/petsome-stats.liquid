{% comment %}
  Petsome: Stats - a tinted-background row of repeatable "stat" blocks
  (a big number/percentage + a short description), 3 columns on
  desktop collapsing to a stacked column on mobile. The stat number
  uses a distinct accent color (different from regular body text), so
  it's a configurable setting rather than hardcoded - defaults to the
  product's "Product accent color (gradient end)" metafield when set,
  falling back to this section's own color setting otherwise.
  Background follows the same pattern via "Product secondary color".
  Generic/reusable across any product.
{% endcomment %}
{%- liquid
  assign secondary_color = product.metafields.custom.product_secondary_color.value | default: section.settings.background_color
  assign number_color = product.metafields.custom.product_accent_color_dark.value | default: section.settings.number_color
-%}
<style>
  #petsome-stats-{{ section.id }} {
    --ps-secondary: {{ secondary_color }};
    --ps-number: {{ number_color }};
    background-color: var(--ps-secondary);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #petsome-stats-{{ section.id }} p {
    margin: 0;
  }

  #petsome-stats-{{ section.id }} .petsome-stats__inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 var(--petsome-padding-x);
    display: flex;
    gap: 40px;
  }

  @media screen and (max-width: 749px) {
    #petsome-stats-{{ section.id }} .petsome-stats__inner {
      flex-direction: column;
    }
  }

  #petsome-stats-{{ section.id }} .petsome-stat {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    text-align: center;
  }

  #petsome-stats-{{ section.id }} .petsome-stat__number {
    font-weight: 800;
    font-size: 4.8rem;
    line-height: 1.3;
    color: var(--ps-number);
    margin: 0;
  }

  #petsome-stats-{{ section.id }} .petsome-stat__description {
    font-size: 1.6rem;
    line-height: 1.5;
    color: rgb(var(--color-foreground));
    margin: 0;
  }
</style>

{%- if section.blocks.size > 0 -%}
  <div id="petsome-stats-{{ section.id }}" class="petsome-stats">
    <div class="petsome-stats__inner">
      {%- for block in section.blocks -%}
        <div class="petsome-stat" {{ block.shopify_attributes }}>
          {%- if block.settings.number != blank -%}
            <p class="petsome-stat__number">{{ block.settings.number }}</p>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="petsome-stat__description">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Petsome: Stats",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "paragraph",
      "content": "If the product has \"Product secondary color\" / \"Product accent color (gradient end)\" metafields set, those values are used instead of the colors below - these only apply as a fallback when the metafields are blank."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color (fallback)",
      "default": "#E8D6C5"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Stat number color (fallback)",
      "info": "The big number uses its own accent color, distinct from regular text.",
      "default": "#F47671"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number / percentage",
          "default": "95%"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Describe what this stat means."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Petsome: Stats",
      "blocks": [
        { "type": "stat" },
        { "type": "stat" },
        { "type": "stat" }
      ]
    }
  ]
}
{% endschema %}
