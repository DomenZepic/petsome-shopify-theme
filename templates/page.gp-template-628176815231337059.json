        "ggXNNhy74R3_text": "<p><span style=\"color:#FFFFFF;\"><strong>Pogost problem pri psih 6+ let</strong></span></p>",
        "ggYLklS4Qus_text": "Artitis pri starejšem psu?",
        "ggxJpCW8Q8l_text": "<p>Se zato tudi tvoj pes ne giblje več tako kot nekoč?</p>",
        "gg2D4JLaBVf_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0970/1284/2821/files/woman-brown-sweater-lady-with-labrador_1.png",
        "gg2D4JLaBVf_srcSet_mobile_src": "https://cdn.shopify.com/s/files/1/0970/1284/2821/files/hf_20260713_163447_2d99eb36-2604-4301-adaf-5d2fc17329e7.png",
