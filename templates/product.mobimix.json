    "petsome_benefits_1": {
      "type": "petsome-benefits",
      "blocks": {
        "benefit_1": {
          "type": "benefit",
          "settings": {
            "image": "shopify://shop_images/Kaching-Bundles-igC1PeA1mofml_AY0kJypTCCc.jpg",
            "icon": "pets",
            "filled_icon": false,
            "title": "Manj bolečin že po 2–3 tednih",
            "text": "<p>Sestavine MobiMixa začnejo delovati takoj. Večina lastnikov opaži, da pes zjutraj vstane lažje in da je v gibanju manj previdnosti. Ne zato, ker bi bila bolečina zakrita, ampak ker se vnetje umirja in hrustanec dobiva podporo, ki jo potrebuje.</p>"
          }
        },
        "benefit_2": {
          "type": "benefit",
          "settings": {
            "image": "shopify://shop_images/Kaching-Bundles-igC1PeA1mofml_AY0kJypTCCc.jpg",
            "icon": "directions_run",
            "filled_icon": false,
            "title": "Lahkotnejše gibanje dan za dnem",
            "text": "<p>Kapsulo preprosto dodaš k dnevnemu obroku. Ni posebnih postopkov, ni kompromisov. Samo dosledna, dnevna podpora, ki sčasoma prinese razliko, ki jo opazite vsak dan.</p>"
          }
        },
        "benefit_3": {
          "type": "benefit",
          "settings": {
            "image": "shopify://shop_images/Kaching-Bundles-igC1PeA1mofml_AY0kJypTCCc.jpg",
            "icon": "bolt",
            "filled_icon": true,
            "title": "Več energije za sprehode in igranje",
            "text": "<p>Ko se vnetje umiri, se vrne igrivost. Lastniki poročajo: pes spet pohiti do vrat, spet zahteva sprehod, spet povleče povodec. Ta trenutek je vreden vsega.</p>"
          }
        },
        "benefit_4": {
          "type": "benefit",
          "settings": {
            "image": "shopify://shop_images/Kaching-Bundles-igC1PeA1mofml_AY0kJypTCCc.jpg",
            "icon": "shield",
            "filled_icon": true,
            "title": "Dolgoročna zaščita sklepov",
            "text": "<p>MobiMix je zasnovan za dolgotrajno uporabo. Idealen za pse nad 5 let, velike pasme in aktivne pse, ki sklepe obremenjujejo vsak dan. Hrustanca, ki ga ni, ne moremo obnoviti, tistega, ki je še tam, pa lahko zaščitimo.</p>"
          }
        }
      },
      "block_order": [
        "benefit_1",
        "benefit_2",
        "benefit_3",
        "benefit_4"
      ],
      "settings": {
        "heading": "<p>Iz ljubezni do naših ljubljenčkov smo razvili celostno formulo za zdrave sklepe in lahkotno gibanje psov.</p>",
        "columns": "2",
        "accent_color": "#f8aaa7",
        "secondary_color": "#e8d6c5",
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "petsome_timeframe_1": {
      "type": "petsome-timeframe",
      "blocks": {
        "tf_1": {
          "type": "timeframe",
          "settings": {
            "highlighted": false,
            "badge_text": "2-3 tedni",
            "title": "Vstane malo lažje.",
            "text": "<p>To je navadno prva stvar, ki jo opazite. Tista sekunda oklevanja zjutraj — začne izginjati. Hoja po stopnicah je manj previdna. Drobne spremembe, ki pa jih ne morete spregledati, ko jih vidite.</p>"
          }
        },
        "tf_2": {
          "type": "timeframe",
          "settings": {
            "highlighted": false,
            "badge_text": "1 mesec",
            "title": "Spet hodi kot bi moral.",
            "text": "<p>Tempo se vrne. Pes bolj pogumno stopa po klančinah. Na sprehodu spet malo zahteva — ne samo sledi. Sprehodi postanejo prijetnejši. Za oba.</p>"
          }
        },
        "tf_3": {
          "type": "timeframe",
          "settings": {
            "highlighted": true,
            "badge_text": "2–3 meseci",
            "title": "Deluje kot mlajši.",
            "text": "<p>To je stavek, ki ga slišimo najpogosteje. Pes se igra. Prinese igračo. Pohiti do vrat. Stvari, ki jih je nehal počati — se vračajo. Po eni za drugo.</p>"
          }
        },
        "tf_4": {
          "type": "timeframe",
          "settings": {
            "highlighted": false,
            "badge_text": "3+ meseci",
            "title": "Zdaj pa ne bi več prenehala.",
            "text": "<p>Ko lastniki vidijo, kaj se zgodi, če za teden pozabijo na kapsulo — se ne ustavijo več. Sklepi so zaščiteni. Pes je aktiven. To je bil cilj od začetka.</p>"
          }
        }
      },
      "block_order": [
        "tf_1",
        "tf_2",
        "tf_3",
        "tf_4"
      ],
      "settings": {
        "heading": "<p>Kaj se zgodi, ko vaš pes začne z MobiMixom?</p>",
        "subheading": "Vsak pes je drugačen. A večina lastnikov opazi prve spremembe hitreje, kot so pričakovali.",
        "columns": "4",
        "background_color": "#faf9f6",
        "accent_color": "#f8aaa7",
        "accent_color_dark": "#f47671",
        "secondary_color": "#e8d6c5",
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
