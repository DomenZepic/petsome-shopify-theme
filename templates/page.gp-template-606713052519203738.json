    "gp_global_section_608195099704164950-3": {
      "type": "gp-global-section-608195099704164950",
      "settings": {
        "section_preload": "false",
        "checksum": "",
        "ggExEXGIl-V_text_-316530330": "Pogosta vprašanja",
        "ggVWCqDsENA_text_-1683906160": "❓ O izdelku MobiMix",
        "ggaYe2PFLxY_childItem_0_600933938": "Pri kateri starosti se lahko z jemanjem MobiMixa?",
        "ggFGnNCJ5tm_text_-1751261936": "MobiMix je primeren za pse vseh pasem in starosti. Pri mladičih priporočamo začetek po približno <strong>5. mesecu starosti</strong>. Če ima pes zdravstvene posebnosti ali ste v dvomih, se pred uporabo posvetujte z veterinarjem.",
        "ggwgxoq9G2N_childItem_0_-888389083": "Kaj se zgodi, če se zaužijejo vse kapsule na enkrat?",
        "ggeBIhY9YPY_text_1502367103": "Če bi pes zaužil večje število kapsul hkrati, lahko pride do <strong>prebavnih težav</strong> (npr. driska, bruhanje). V takem primeru priporočamo, da <strong>nemudoma kontaktirate veterinarja</strong>.",
        "ggGtMSkAGui_childItem_0_1299223426": "Kako shranjevati MobiMix?",
        "ggYJeV3uwOO_text_-1275891484": "Izdelek shranjujte v <strong>suhem in temnem prostoru</strong>, pri sobni temperaturi. Po vsaki uporabi embalažo dobro zaprite in hranite <strong>izven dosega otrok in živali</strong>.",
        "ggySyZ1a1Vk_childItem_0_-1078830395": "Ali lahko uporabljamo MobiMix v obdobju brejosti ali laktacije?",
        "ggnOPNMV_00_text_-1748128706": "Uporabe v obdobju brejosti ali laktacije <strong>ne priporočamo</strong>, saj sestavine v tem obdobju niso bile posebej testirane. Pred uporabo se posvetujte z veterinarjem.",
        "ggJW65DjQGD_childItem_0_-1060079892": "Kakšne so lahko koristi mojemu psu od jemanja MobiMixa?",
        "gg815QyE5ju_text_949738137": "MobiMix lahko podpira <strong>sklepe, kosti in vezivna tkiva</strong>, pomaga pri <strong>ohranjanju gibljivosti</strong> ter lajša znake, kot so togost, oklevanje pri vstajanju, manjša želja po gibanju ali občasno šepanje – še posebej pri starejših, aktivnih ali večjih psih.",
        "ggEvquBC-EC_childItem_0_-655281354": "Kako pogosto naj dam svojemu psu MobiMix?",
        "ggXMvzkVP2Y_text_714130794": "MobiMix se daje <strong>enkrat dnevno</strong>, skupaj z obrokom. Priporočen odmerek je odvisen od teže psa in je naveden na embalaži. Za najboljše rezultate priporočamo <strong>redno, dolgotrajno uporabo</strong>.",
        "gg8qHLWFfLP_childItem_0_625478288": "Ali so prehranska dopolnila primerna za vse pasme psov?",
        "ggL_-magVsi_text_-1567259813": "Da. MobiMix je primeren za <strong>vse pasme in velikosti psov</strong>, pomembno pa je, da upoštevate <strong>pravilen odmerek glede na telesno težo</strong>.",
        "gg0ZKqFGxiB_childItem_0_1330601517": "Ali lahko odprem kapsulo in jo stresem po hrani?",
        "ggCcz52-O7j_text_1985928168": "Da. Če pes kapsule ne želi ali ne more pogoltniti, lahko kapsulo <strong>odprete in vsebino posujete po hrani</strong>. Ovojnico kapsule v tem primeru zavrzite.",
        "ggSIEb__1cd_childItem_0_1875118536": "Koliko časa bo trajalo, da bom pri svojem psu opazil izboljšanje?",
        "ggwY9nbFJgC_text_1395192451": "Prve spremembe nekateri lastniki opazijo že po <strong>2–4 tednih</strong>, vendar je za poln učinek običajno potrebnih <strong>8–12 tednov redne uporabe</strong>. Hitrost izboljšanja je odvisna od starosti psa, stopnje težav in doslednosti uporabe.",
        "gg0C-TGXbDo_text_-1829217772": "🚚 Dostava, vračila in naročila",
        "ggYeQQyTcf1_childItem_0_765575508": "Kako hitro prejmem naročilo?",
        "ggTubYT6W0E_text_-1387705997": "Naročila običajno odpremimo <strong>v 24 urah</strong> na delovni dan. Dostava po Sloveniji praviloma traja <strong>1–3 delovne dni</strong>, odvisno od dostavne službe.",
        "ggzVt9WlwCj_childItem_0_1977002485": "Ali nudite brezplačno dostavo?",
        "ggS3cqbHPNn_text_-1390525456": "Da. <strong>Brezplačno dostavo</strong> nudimo pri naročilih nad določenim zneskom, ki je jasno označen v košarici. Pri manjših naročilih se strošek dostave prikaže pred zaključkom nakupa – brez skritih stroškov.",
        "ggWPkHqkFhI_childItem_0_1826309587": "Kaj če z izdelkom ne bom zadovoljen/-na?",
        "ggucgl5YtzV_text_1598338238": "Nakup pri nas je <strong>brez tveganja</strong>. Če z izdelkom <strong>v 60 dneh</strong> ne boste zadovoljni, nam to sporočite in <strong>povrnemo celotno kupnino</strong> – brez zapletov in dodatnih vprašanj.",
        "gg0AuU2Q6md_childItem_0_1677123268": "Kako uveljavim vračilo?",
        "ggPJeFmY_Cg_text_1240599940": "Preprosto. Pišite nam na <a href=\"mailto:info@pet-some.eu\" target=\"_blank\"><strong><u>info@pet-some.eu</u></strong></a> in navedite številko naročila. Vodili vas bomo skozi hiter in enostaven postopek vračila.",
        "ggA0AdY1ivy_childItem_0_1450390682": "Ali lahko naročilo spremenim ali prekličem?",
        "gg4Z9Rwswft_text_278993108": "Če naročilo še ni bilo odpremljeno, ga lahko <strong>spremenite ali prekličete</strong>. V tem primeru nam čim prej pišite na <a href=\"mailto:info@pet-some.eu\" target=\"_blank\"><strong><u>info@pet-some.eu</u></strong></a> in uredili bomo vse potrebno."
      }
    },
    "gp_section_606713067635475204": {
      "type": "gp-section-606713067635475204",
      "settings": {
        "section_preload": "true",
        "checksum": "75ffcbdf2573d0da6f9397acca87927be38581caaabca6f8b5fe4538596d59a5_1_1_1_0__1",
        "ggF5nAtNXoc_text": "Porabila sem 240 € za tri različne dodatke, preden me je veterinarka vprašala zakaj še vedno uporabljam \"tiste, ki ne delujejo\".",
        "ggt1Cc3qyHv_text": "<p><span style=\"background-color:transparent;color:#555555;font-size:16px;\"><i>Nato sem odkrila eno stvar, ki je vse spremenila v treh &nbsp;tednih.</i></span></p>",
        "gg5PgEtY5HT_text": "<p><strong>Ana Marić</strong></p>",
        "gg5wX0-CegJ_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0970/1284/2821/files/hf_20260209_170851_86e338bc-f84a-4c37-be8f-870a95760a16.png",
        "gg5wX0-CegJ_srcSet_mobile_src": "https://cdn.shopify.com/s/files/1/0970/1284/2821/files/hf_20260209_170851_86e338bc-f84a-4c37-be8f-870a95760a16.png",
        "ggwEpXzBV2R_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:16px;\">Luna se na kavč ni povzpela že osem mesecev. Zveni malo. Pa ni.&nbsp;</span></p><p>&nbsp;</p><p><span style=\"background-color:transparent;color:#000000;font-size:16px;\">Enajst let je bil vsak večer enak. Jaz se usedem, ona skoči gor. Skupaj gledava televizijo, njena velika glava pa počiva na mojem kolenu. Potem je nekega dne nehala. Prišla bi do kavča, pogledala gor in ... se ulegla na tla. Brez cviljenja. Brez poskusa. Preprosto se je vdala. Takrat sem razumela, da se dogaja nekaj hujšega. Luna ni le fizično pešala. Izgubljala je svojo osebnost.</span></p><p>&nbsp;</p><p><span style=\"background-color:transparent;color:#000000;font-size:16px;\">Takrat sem razumela, da se dogaja nekaj hujšega. Luna ni le fizično pešala. Izgubljala je svojo osebnost.</span></p>",
        "ggqYDjmJSX8_text": "<span style=\"background-color:transparent;color:#000000;font-size:28px;\">\"To je pač starost\" — tri besede, ki jih sovražim</span>",
        "gg5D0nU6OAr_text": "<p>Peljala sem jo k veterinarju. Standardni pregled, veliko kimanja in nato tiste tri besede: \"To je pač starost.\"&nbsp;</p><p>&nbsp;</p><p>Domov sem se peljala s psičko, ki je včasih celo pot z glavo visela skozi okno. Tisti dan je samo sedela. Tiho. Če imate starejšo psičko, staro med 8 in 14 leti — in ste gledali, kako počasi postaja drugačna žival — točno veste, o čemer govorim.&nbsp;</p><p>&nbsp;</p><p>Pri 80 % psov, starejših od 8 let, težave s sklepi tiho kradejo energijo, igrivost in voljo do gibanja. Večini lastnikov rečejo, naj to sprejmejo. Naj se sprijaznijo. Naj se poslovijo od psičke, ki so jo poznali. Jaz se nisem mogla.&nbsp;</p><p>&nbsp;</p><p>In kar sem odkrila — po mesecih iskanja — me je presenetilo. Ker odgovor sploh ni bil takšen, kot sem pričakovala.</p>",
        "ggRn82zsuGs_text": "Kako sem preizkusila vse, a nič ni pomagalo",
        "ggFCbYRVVnf_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Nisem nekdo, ki se hitro preda. Zato sem se lotila dela. Najprej osnovni glukozamin iz trgovine za hišne živali. Dva meseca. Skoraj nič. Potem dražji, veterinarsko priporočen dodatek. Tri mesece. Luna se je še vedno vsako jutro s težavo dvigovala. CBD-olje. Vsi so prisegali nanj. Zavonjala ga je in obrnila glavo stran. Nobene razlike. Poskusila sem celo krajšati sprehode — mislila sem, da počitek pomaga. Postala je samo še bolj toga in šibka.&nbsp;</span></p><p>&nbsp;</p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Porabila sem več kot 300 € in šest mesecev za stvari, ki niso delovale. In Luni je bilo vedno slabše.&nbsp;</span></p><p>&nbsp;</p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Najhujši trenutek je prišel neko nedeljsko popoldne. Njena najljubša žoga se je zakotalila pod kavč. Včasih jo je lovila, kot da ji gre za življenje. Pogledala jo je. Pogledala je mene. In odšla k svoji postelji. Odšla sem v kopalnico in se zjokala.&nbsp;</span></p><p>&nbsp;</p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Tisto noč sem spet začela iskati. Tokrat sem vtipkala nekaj drugega: \"Zakaj dodatki za sklepe pri psih prenehajo delovati?\" Kar sem našla, je spremenilo vse.</span></p>",
        "gg941jG98lU_text": "<span style=\"background-color:transparent;color:#000000;font-size:28px;\">Česa vam nihče ne pove o dodatkih za sklepe</span>",
        "ggYQFUfdlef_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">99 % dodatkov na trgu obravnava samo 1 od 3 stvari, ki uničujejo sklepe vaše psičke. Tukaj je tisto, kar se v resnici trenutno dogaja znotraj vaše starejše psičke. Težav s sklepi ne povzroča le ena stvar, temveč tri hkrati:&nbsp;</span></p><p>&nbsp;</p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\"><strong>-Razpadanje hrustanca</strong>: Zaščitna blazina med kostmi se obrabi.&nbsp;</span></p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\"><strong>-Kronično vnetje</strong>: Sklepi otečejo, se zakrčijo in bolijo. Zato psi ne želijo več hoditi — ne zaradi lenobe, ampak zaradi bolečine.&nbsp;</span></p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\"><strong>-Oksidativni stres</strong>: Poškodbe zaradi prostih radikalov pospešijo razpad sklepov na celični ravni.&nbsp;</span></p><p>&nbsp;</p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Osnovni glukozamin cilja samo na hrustanec. To je vse. Medtem ko ljubljenčku dajete en dodatek, druga dva vzroka delujeta brez nadzora — uničujeta sklepe, ki jih skušate zaščititi. To je tako, kot bi z lončkom zajemali vodo iz potapljajočega se čolna, medtem ko sta dve luknji še vedno odprti. Nič čudnega, da nič ni pomagalo.</span></p>",
        "ggi9nnlUOM8_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0970/1284/2821/files/hf_20260225_173302_bb2e7113-83c7-4ee0-aa44-c0f7906ff754.jpg",
        "gg5iX_agiWg_text": "Zakaj celovita podpora spremeni vse?",
        "ggsc6ZjRhOH_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Ko sem to razumela, sem vedela, kaj moram najti. Ne le dodatka, ampak sistem — nekaj, kar udari na vse tri vzroke hkrati. Takrat sem naletela na MobiMix.&nbsp;</span></p><p>&nbsp;</p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Bila sem skeptična. Vem, vem — vse se reklamira. Že prej sem bila razočarana. Ampak tole je bilo drugače. Namesto dveh sestavin, kot jih ima večina dodatkov, MobiMix uporablja osem — vsaka cilja na specifičen del problema:&nbsp;</span></p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\"><strong>- Glukozamin + hondroitin:</strong> obnavljata in ščitita hrustanec.&nbsp;</span></p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\"><strong>- Zelenoustna školjka:</strong> močno naravno protivnetno delovanje in esencialni minerali.&nbsp;</span></p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\"><strong>- Kurkuma + ingver + vražji krempelj:</strong> napadejo vnetje s treh strani.&nbsp;</span></p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\"><strong>- Šipek + vitamin C: </strong>antioksidantna zaščita pred celičnimi poškodbami.&nbsp;</span></p><p>&nbsp;</p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">To ni le dodatek. To je celovit protokol za okrevanje sklepov v eni tableti. Razvit v Sloveniji. Po evropskih farmacevtskih standardih. Priporočen s strani veterinarjev. Tisto noč sem ga naročila.</span></p>",
        "ggyiBjYoqpn_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0970/1284/2821/files/image00002_9bfcbcfd-8a57-4638-a822-e6ac9ebe4aa5.jpg",
        "ggJzLLZu3wM_text": "Tri mesece kasneje",
        "ggbLbJ091fv_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Luna ni le ohranila izboljšanja. Postala je&nbsp;<i>boljša</i>.</span></p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Več ne liže svojih sklepov. Vstaja brez tistega bolečega obotavljanja. Teče po stopnicah—nekaj, za kar sem mislila, da ne bom nikoli več videla. Včeraj je skočila na kavč poleg mene, nekaj, česar ni naredila tri leta.</span></p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Ampak največja sprememba ni v Luni.</span></p><p>&nbsp;</p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\"><strong>Največja sprememba je v meni.</strong></span></p><p>&nbsp;</p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Nisem več nemočna. Nisem več polna krivde. Ne ležim več budna ponoči in se sprašujem, ali lahko naredim še kaj več, ker&nbsp;<i>vem</i>, da delam vse, kar lahko.</span></p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Rešila sem svojo psičko pred trpljenjem. In s tem sem rešila sebe pred neznosno bolečino gledanja nekoga, ki ga ljubim, kako trpi, medtem ko sem stala ob strani, nemočna.</span></p>",
        "ggIkxxv5fln_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0970/1284/2821/files/MobiMix_eng.jpg",
        "ggz3WyIank3_label": "<p>Preveri MobiMix</p>"
      }
    },
    "gp_section_606713067736138650": {
      "type": "gp-section-606713067736138650",
      "settings": {
        "checksum": "a7422d37d1f5df2275aaf705af75f8e7d65a033461b66c247aa6eb52566ba91a_1_1_1_0__1",
        "ggsyq7NHr6l_text": "Zakaj je MobiMix deloval, ko nič drugega ni?",
        "ggIHFK4PZr8_text": "<p>Od takrat sem naredila raziskavo. Hotela sem razumeti <i>zakaj</i> je to delovalo, ko je vse drugo spodletelo.</p>",
        "ggeliOuQnHQ_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0970/1284/2821/files/MobiMix_eng_2.png",
        "ggZsTTmRCbt_text": "<p>Other</p>",
        "ggRYAOyt2lq_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0970/1284/2821/files/5900586_3728_1.png",
        "ggqbu4BAkNj_text": "<p>MobiMix</p>",
        "ggAB8k33zlr_text": "<p>Drugi dodatki</p>",
        "gg81Va9oeHX_text": "<p>8 sestavin</p>",
        "ggwFRgx1LZt_text": "<p>Nadzor vnetja</p>",
        "ggukehktQEf_text": "<p><strong>Obnova hrustanca</strong></p>",
        "ggoSFlpmuRJ_text": "<p>Oksidativna zaščita</p>",
        "ggSDru2FIy2_text": "<p>EU standardi</p>",
        "ggUwVInvGAE_text": "<p>Rezultati v 2-3 tednih</p>",
        "ggXihxhmePo_text": "<p>Transparentna formula</p>"
      }
    },
    "gp_section_606713067769692932": {
      "type": "gp-section-606713067769692932",
      "settings": {
        "checksum": "9f6a18a88962a8e013fd0c9a6bbb8c88b08ef0b8bb8c4aa54cd0106f0be7b4ae_1_1_1_0__1",
        "ggYUjviqfbS_text": "In kar je najbolje - nisem bila edina.",
        "ggYCT6095vQ_text": "<p>Karmen</p>",
        "gghHlf119Vi_childItem_0": "<p>Preverjen kupec</p>",
        "ggcJ8SJlMdw_text": "<p><span style=\"background-color:transparent;color:#444444;font-size:13pt;\"><i>\"Maj je bil tik pred operacijo, saj na levo nogo niti stopiti ni mogel več... Po enem mesecu je Maj zopet tekel.\"</i></span></p>",
        "ggabY7-lXBq_text": "<p>Maja</p>",
        "ggWxBqftfNB_childItem_0": "<p>Preverjen kupec</p>",
        "ggRMgi86fEf_text": "<p><span style=\"background-color:transparent;color:#444444;font-size:13pt;\"><i>\"Od močnega šepanja in 50m sprehoda sva takrat po 3 mesecih uporabe prišla do normalnega stanja.\"</i></span></p>",
        "ggBo_lVNyzV_text": "<p>Tomaž</p>",
        "ggPVnOBonS4_childItem_0": "<p>Preverjen kupec</p>",
        "ggnba8h-LZB_text": "<p><span style=\"background-color:transparent;color:#444444;font-size:13pt;\"><i>\"Običajno ne verjamem takim stvarem, tokrat pa res.\"</i></span></p>",
        "ggIjUJRIMWb_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">To niso plačane izjave. To so obupani lastniki hišnih ljubljenčkov, ki so, tako kot jaz, poskusili vse in končno našli nekaj, kar dejansko deluje.</span></p>",
        "ggFLSvWZ7GL_text": "Imate izbiro.",
        "ggqjs_fVYf5_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Zdaj ste tam, kjer sem bila jaz pred tremi meseci.</span></p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Gledate svojega psa, kako se bori. Počutite se nemočni. Sprašujete se, ali sploh obstaja kaj, kar lahko dejansko pomaga, ali bo to tako od zdaj naprej.</span></p><p>&nbsp;</p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Lahko še naprej poskušate nepopolne rešitve, ki obravnavajo samo del problema. Lahko še naprej porabljate denar za dodatke, ki dajejo velike obljube, ampak dajejo minimalne rezultate.</span></p><p>&nbsp;</p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Ali pa lahko poskusite nekaj drugačnega. Nekaj popolnega. Nekaj, kar obravnava vse tri osnovne vzroke težav s sklepi.</span></p><p>&nbsp;</p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">MobiMix prihaja z 60-dnevno garancijo vračila denarja. Če ne vidite vidnega izboljšanja—če vaš pes ne vstaja lažje, se ne giblje bolje, ne kaže manj bolečine—dobite polno povračilo.</span></p><p><span style=\"background-color:transparent;color:#000000;font-size:12pt;\">Dobesedno nimate česa izgubiti. Razen morda tega strašnega občutka nemoči.</span></p>"
      }
    },
