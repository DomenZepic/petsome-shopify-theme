        "ggTxZqN_p3e_srcSet_desktop_src_-2147182132": "https://cdn.shopify.com/s/files/1/0970/1284/2821/files/MobiGuarantee.png",
        "ggqu5dzJZ95_text_2033352156": "Pri Petsome želimo, da vsak MobiMix ljubljenčku izboljša gibanje. Če ste v dvomih, ali je ta izdelek za vašega ljubljenčka - ni panike. Vaše naročilo je zaščiteno z 60-dnevno garancijo vračila denarja. Brez slabe vesti.",
        "ggrQ8NXiTjm_srcSet_desktop_src_1363799831": "https://cdn.shopify.com/s/files/1/0970/1284/2821/files/mobiGarancijaImg.png",
