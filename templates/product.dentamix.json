          "settings": {
            "image": "shopify://shop_images/Untitled_design_90_23d1c325-2ca9-408a-adbc-21cf722c055a.webp",
            "dog_name": "Rosa, 11-letna maltežanka",
            "issue": "Rjave obloge",
            "text": "<p>Rosa je imela rjave obloge ob dlesnih in skrbela jo je anestezija. Z rednim DentalMixom so zobje videti čistejši, brez postopka pri veterinarju.</p>"
          }
        },
        "story_3": {
          "type": "story",
          "settings": {
            "image": "shopify://shop_images/image00004_db7b8cc8-6684-47d2-980a-96f678167a77.png",
            "dog_name": "Dante, 12-letni ovčar",
            "issue": "Starejši pes, ne pusti ščetke",
            "text": "<p>Dante je starejši ovčar in ščetkanja ne prenese. Prašek na hrani je preprosta rešitev — zadaha ni več, lastnica pa mirna.</p>"
          }
        }
      },
