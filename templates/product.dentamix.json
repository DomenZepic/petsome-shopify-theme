            "product_petsome_professional_review_BGLaVX": {
              "type": "product_petsome-professional-review",
              "name": "Petsome: Expert review",
              "settings": {
                "visibility": "desktop-hidden",
                "image": "shopify://shop_images/unnamed_1.jpg",
                "rating": 5,
                "quote": "\"Več kot 80 % psov ima do tretjega leta vidne težave z zobmi — večina lastnikov pa rednega ščetkanja preprosto ne zmore. DentalMix deluje drugače: skozi pasjo slino, ki obliva zobe ves dan. Pomaga vezati kalcij, preden se strdi v zobni kamen, in preprečuje, da bi se obloge sprijele. Enostavna dnevna podpora proti zadahu in za čistejše zobe — brez ščetkanja.\"",
