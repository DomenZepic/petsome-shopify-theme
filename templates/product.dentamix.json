    "petsome_benefits_1": {
      "type": "petsome-benefits",
      "blocks": {
        "benefit_1": {
          "type": "benefit",
          "settings": {
            "image": "shopify://shop_images/hf_20260709_182705_61b08430-0bb6-4e61-844d-e3cddbacd2d2.png",
            "icon": "pets",
            "filled_icon": false,
            "title": "Manj zadaha že v 7–14 dneh",
            "text": "<p>DentalMix deluje skozi slino od prvega dne. Večina lastnikov opazi, da tisti zadah, ki jih je odbijal, počasi popušča — ne zato, ker bi ga prekrili, ampak ker se bakterije, ki ga povzročajo, umirjajo.</p>"
          }
        },
        "benefit_2": {
          "type": "benefit",
          "settings": {
            "image": "shopify://shop_images/hf_20260709_190328_9e06e438-fa32-48d3-9e3c-fdb3e405526b.png",
            "icon": "directions_run",
            "filled_icon": false,
            "title": "Brez ščetkanja, brez borbe",
            "text": "<p>Prašek preprosto potreseš na obrok. Nič stiskanja gobčka, nič vsakodnevne bitke, ki jo pes vedno dobi. Samo dosledna dnevna nega, ki jo pes komaj opazi.</p>"
          }
        },
        "benefit_3": {
          "type": "benefit",
          "settings": {
            "image": "shopify://shop_images/hf_20260709_180016_bbaa73f9-3aab-4980-a5a7-4cdc6680f767.png",
            "icon": "bolt",
            "filled_icon": true,
            "title": "Spet ga crkljaš od blizu",
            "text": "<p>Ko zadah popusti, se vrne tisto, kar imaš najraje — crkljanje od blizu, brez odmika. To je trenutek, ki šteje.</p>"
          }
        },
        "benefit_4": {
          "type": "benefit",
          "settings": {
            "image": "shopify://shop_images/hf_20260709_190433_b72c1c33-4f5d-43ed-a438-fb50be355b7a.png",
            "icon": "shield",
            "filled_icon": true,
            "title": "Manj zobnega kamna, dolgoročno",
            "text": "<p>DentalMix je zasnovan za vsakodnevno, dolgotrajno uporabo. Vezanje kalcija preprečuje, da bi se obloge strdile v kamen — zato zobje ostanejo čistejši dlje, ne le prvi teden.</p>"
          }
        }
      },
      "block_order": [
        "benefit_1",
        "benefit_2",
        "benefit_3",
        "benefit_4"
      ],
      "settings": {
        "heading": "<p>Enostavna dnevna nega proti zadahu in za čistejše zobe — brez ščetkanja.</p>",
        "columns": "2",
        "accent_color": "#f8aaa7",
        "secondary_color": "#e8d6c5",
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "petsome_timeframe_1": {
      "type": "petsome-timeframe",
      "blocks": {
        "tf_1": {
          "type": "timeframe",
          "settings": {
            "highlighted": false,
            "badge_text": "7–14 dni",
            "title": "Zadah popusti.",
            "text": "<p>To je navadno prva stvar, ki jo opaziš. Tisti zadah, ki te je odbijal, postane opazno milejši. Drobna sprememba, ki je ne moreš spregledati, ko jo enkrat zaznaš.</p>"
          }
        },
        "tf_2": {
          "type": "timeframe",
          "settings": {
            "highlighted": false,
            "badge_text": "3–4 tedni",
            "title": "Zobje delujejo čistejši.",
            "text": "<p>Obloge ob dlesnih so videti svetlejše, površina zob bolj gladka. Ne čez noč — a razlika, ki jo opaziš, ko psa pogledaš v gobček.</p>"
          }
        },
        "tf_3": {
          "type": "timeframe",
          "settings": {
            "highlighted": true,
            "badge_text": "2–3 meseci",
            "title": "Manj vidnega kamna.",
            "text": "<p>Novih oblog je manj, ker se kalcij sproti veže in ne strdi. Zobje ostajajo čistejši, zadaha pa manj — dan za dnem.</p>"
          }
        },
        "tf_4": {
          "type": "timeframe",
          "settings": {
            "highlighted": false,
            "badge_text": "3+ meseci",
            "title": "Zadaha ni več.",
            "text": "<p>Ko lastniki vidijo razliko, ne prenehajo več. Prašek je del vsakdanje rutine, zadaha ni več, crkljanje od blizu pa spet naravno. To je bil cilj od začetka.</p>"
          }
        }
      },
      "block_order": [
        "tf_1",
        "tf_2",
        "tf_3",
        "tf_4"
      ],
      "settings": {
        "heading": "<p>Kaj se zgodi, ko vaš pes začne z DentalMixom?</p>",
        "subheading": "Vsak pes je drugačen. A večina lastnikov opazi prve spremembe hitreje, kot so pričakovali.",
        "columns": "4",
        "background_color": "#faf9f6",
        "accent_color": "#f8aaa7",
        "accent_color_dark": "#f47671",
