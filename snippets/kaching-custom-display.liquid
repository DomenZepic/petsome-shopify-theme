{% comment %}
  Renders a custom UI driven by an existing Kaching Bundles app block's
  data/logic on the same page. Hides Kaching's own widget visually but keeps
  it mounted so its pricing/discount/cart/gift logic keeps working.

  Accepts:
  - block: {Object} block object (type product_kaching-custom-display).
  - section: {Object} parent section object.

  Usage:
  {% render 'kaching-custom-display', block: block, section: section %}
{% endcomment %}
{%- liquid
  assign accent_color = product.metafields.custom.product_accent_color.value | default: block.settings.accent_color
  assign accent_color_dark = product.metafields.custom.product_accent_color_dark.value | default: block.settings.accent_color_dark
  assign secondary_color = product.metafields.custom.product_secondary_color.value | default: block.settings.secondary_color
-%}
<style>
  kaching-bundle {
    display: none !important;
  }

  #kaching-custom-display-{{ section.id }}-{{ block.id }} {
    --kaching-accent: {{ accent_color }};
    --kaching-secondary: {{ secondary_color }};
    {%- if accent_color_dark != blank -%}
      --kaching-accent-dark: {{ accent_color_dark }};
    {%- else -%}
      --kaching-accent-dark: color-mix(in srgb, var(--kaching-accent) 70%, black);
    {%- endif -%}
    --kaching-secondary-tint: color-mix(in srgb, var(--kaching-secondary) 40%, white);
    --kaching-gift-bg: rgba(193, 122, 79, 0.2);
    display: block;
  }

  #kaching-custom-display-{{ section.id }}-{{ block.id }} [hidden] {
    display: none !important;
  }

  .kaching-custom-display p {
    margin: 0;
  }

  .kaching-custom-display__inner {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .kaching-custom-display__top {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .kaching-custom-display__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    width: 100%;
  }

  .kaching-custom-display__header-left {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1 0 0;
    min-width: 0;
  }

  .kaching-custom-display__title {
    font-weight: 700;
    font-size: 2.2rem;
    line-height: 1.4;
    color: rgb(var(--color-foreground));
  }

  .kaching-custom-display__savings-badge {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: 4px;
    padding: 4px 12px;
    border-radius: 6px;
    background: linear-gradient(180deg, var(--kaching-accent) 0%, var(--kaching-accent-dark) 100%);
  }

  .kaching-custom-display__savings-badge .material-icon {
    font-size: 1.6rem;
    color: {{ block.settings.light_text_color }};
  }

  .kaching-custom-display__savings-badge-text {
    font-weight: 700;
    font-size: 1.2rem;
    line-height: 1.05;
    color: {{ block.settings.light_text_color }};
    white-space: nowrap;
  }

  .kaching-custom-display__price-block {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    text-align: right;
    flex-shrink: 0;
  }

  .kaching-custom-display__price-current {
    font-weight: 700;
    font-size: 2.4rem;
    line-height: 1.4;
    color: rgb(var(--color-foreground));
    white-space: nowrap;
  }

  .kaching-custom-display__price-compare {
    font-weight: 400;
    font-size: 1.6rem;
    line-height: 1.5;
    color: #565858;
    text-decoration: line-through;
    white-space: nowrap;
  }

  .kaching-custom-display__tiles {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .kaching-custom-display__loading,
  .kaching-custom-display__error {
    font-size: 1.4rem;
    color: rgba(var(--color-foreground), 0.7);
  }

  .kaching-tile-wrapper {
    border-radius: 12px;
    overflow: hidden;
  }

  .kaching-tile-wrapper__label {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px 12px 2px;
    font-weight: 700;
    font-size: 1.4rem;
    line-height: 1.3;
    text-align: center;
  }

  /* Recommended tile: beige by default, switches to accent when selected */
  .kaching-tile-wrapper--recommended {
    background-color: var(--kaching-secondary);
  }

  .kaching-tile-wrapper--recommended .kaching-tile-wrapper__label {
    color: rgb(var(--color-foreground));
  }

  .kaching-tile-wrapper--recommended:has(.kaching-tile--selected) {
    background-color: var(--kaching-accent);
  }

  .kaching-tile-wrapper--recommended:has(.kaching-tile--selected) .kaching-tile-wrapper__label {
    color: {{ block.settings.light_text_color }};
  }

  /* Best tile: black by default, switches to accent when its tile is selected */
  .kaching-tile-wrapper--best {
    background-color: #0e1111;
  }

  .kaching-tile-wrapper--best .kaching-tile-wrapper__label {
    color: #ffffff;
  }

  .kaching-tile-wrapper--best:has(.kaching-tile--selected) {
    background-color: var(--kaching-accent);
  }

  .kaching-tile-wrapper--best:has(.kaching-tile--selected) .kaching-tile-wrapper__label {
    color: {{ block.settings.light_text_color }};
  }

  .kaching-tile {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    text-align: left;
    background-color: #ffffff;
    border: 2px solid #e7e7e7;
    border-radius: 12px;
    padding: 12px;
    font-family: inherit;
    cursor: pointer;
  }

  .kaching-tile-wrapper--recommended .kaching-tile {
    border-color: var(--kaching-secondary);
    background-color: #ffffff;
  }

  .kaching-tile-wrapper--best .kaching-tile {
    border-color: #0e1111;
    background-color: #ffffff;
  }

  /* Selected tile: always accent color, regardless of which tier */
  .kaching-tile--selected {
    border-color: var(--kaching-accent) !important;
    background-color: color-mix(in srgb, var(--kaching-accent) 20%, white) !important;
  }

  .kaching-tile:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .kaching-tile__image {
    flex-shrink: 0;
    width: 100px;
    height: 100px;
    border-radius: 8px;
    background-color: #f4f4f4;
    background-size: cover;
    background-position: center;
  }

  .kaching-tile__content {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1 0 0;
    min-width: 0;
  }

  .kaching-tile__title {
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.2;
    color: rgb(var(--color-foreground));
  }

  .kaching-tile__price {
    font-weight: 700;
    font-size: 1.6rem;
    line-height: 1.3;
    color: rgb(var(--color-foreground));
  }

  .kaching-tile__dosage {
    font-weight: 400;
    font-size: 1.4rem;
    line-height: 1.3;
    color: #565858;
  }

  .kaching-tile__unavailable {
    font-size: 1.2rem;
    color: #c0392b;
    font-weight: 700;
  }

  .kaching-custom-display__disclaimer {
    font-size: 1.4rem;
    line-height: 1.3;
    color: rgb(var(--color-foreground));
    text-align: center;
  }

  .kaching-custom-display__gifts {
    background-color: #ffffff;
    border: 2px solid var(--kaching-secondary);
    border-radius: 12px;
    overflow: hidden;
  }

  .kaching-custom-display__gifts-heading {
    margin: 0;
    padding: 8px 12px;
    background-color: var(--kaching-secondary);
    color: rgb(var(--color-foreground));
    font-weight: 700;
    font-size: 2rem;
    text-align: center;
    text-transform: uppercase;
  }

  @media screen and (max-width: 749px) {
    .kaching-custom-display__gifts-heading {
      font-size: 1.8rem;
    }
  }

  .kaching-custom-display__gifts-list {
    display: flex;
    gap: 12px;
    padding: 12px;
  }

  .kaching-gift {
    flex: 1 0 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px;
    background-color: var(--kaching-gift-bg);
    border: 2px dashed #b7b8b8;
    border-radius: 12px;
    text-align: center;
  }

  .kaching-gift__image {
    width: 40px;
    height: 40px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .kaching-gift__icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .kaching-gift__icon .material-icon {
    font-size: 3.2rem;
    color: rgb(var(--color-foreground));
  }

  .kaching-gift__title {
    font-size: 1.4rem;
    line-height: 1.3;
    color: rgb(var(--color-foreground));
  }

  .kaching-gift__compare-price {
    font-size: 1.2rem;
    line-height: 1.3;
    color: rgb(var(--color-foreground));
    text-decoration: line-through;
  }
</style>

<div
  class="kaching-custom-display-container"
  style="
    margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;
    margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;
  "
  {{ block.shopify_attributes }}
>
  <kaching-custom-display
    id="kaching-custom-display-{{ section.id }}-{{ block.id }}"
    class="kaching-custom-display"
    data-section="{{ section.id }}"
    data-capsules-per-package="{{ block.settings.capsules_per_package }}"
    data-capsules-per-day-by-size="{{ block.settings.capsules_per_day_by_size }}"
    data-product-title="{{ product.title | escape }}"
  >
    <div class="kaching-custom-display__inner">
      <div class="kaching-custom-display__top">
        <div class="kaching-custom-display__header" data-header-container hidden>
          <div class="kaching-custom-display__header-left">
            <p class="kaching-custom-display__title" data-header-title></p>
            <span class="kaching-custom-display__savings-badge" data-savings-badge hidden>
              {% render 'material-icon', icon: 'sell' %}
              <span class="kaching-custom-display__savings-badge-text" data-savings-badge-text></span>
            </span>
          </div>
          <div class="kaching-custom-display__price-block">
            <p class="kaching-custom-display__price-current" data-header-price-current></p>
            <p class="kaching-custom-display__price-compare" data-header-price-compare hidden></p>
          </div>
        </div>
        <div class="kaching-custom-display__tiles" data-tiles-container>
          <p class="kaching-custom-display__loading">{{ 'accessibility.loading' | t }}</p>
        </div>
        {%- if block.settings.disclaimer_text != blank -%}
          <div class="kaching-custom-display__disclaimer">{{ block.settings.disclaimer_text }}</div>
        {%- endif -%}
      </div>
      <div class="kaching-custom-display__gifts" hidden>
        {% if block.settings.gifts_heading != blank %}
          <p class="kaching-custom-display__gifts-heading">{{ block.settings.gifts_heading }}</p>
        {% endif %}
        <div class="kaching-custom-display__gifts-list" data-gifts-container></div>
      </div>
    </div>
  </kaching-custom-display>
</div>

<script src="{{ 'kaching-custom-display.js' | asset_url }}" defer="defer"></script>
