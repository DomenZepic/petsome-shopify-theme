{% comment %}
  Renders a custom UI driven by an existing Kaching Bundles app block's
  data/logic on the same page. Hides Kaching's own widget visually but keeps
  it mounted so its pricing/discount/cart/gift logic keeps working.

  Accepts:
  - block: {Object} block object (type product_kaching-custom-display).
  - section: {Object} parent section object.

  Usage:
  {% render 'kaching-custom-display', block: block, section: section %}
{% endcomment %}
<style>
  kaching-bundle {
    display: none !important;
  }

  .kaching-custom-display__heading {
    font-weight: 700;
    font-size: 1.6rem;
    margin: 0 0 1rem;
    color: rgb(var(--color-foreground));
  }

  .kaching-custom-display__tiles {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .kaching-custom-display__loading,
  .kaching-custom-display__error {
    font-size: 1.4rem;
    color: rgba(var(--color-foreground), 0.7);
  }

  .kaching-tile {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.2rem;
    width: 100%;
    text-align: left;
    background: #ffffff;
    border: 0.2rem solid #e7e7e7;
    border-radius: 1.2rem;
    padding: 1.2rem;
    font-family: inherit;
    cursor: pointer;
    transition: border-color 0.15s ease;
  }

  .kaching-tile:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .kaching-tile--selected {
    border-color: #f8aaa7;
  }

  .kaching-tile[data-badge-style="recommended"] {
    background: #f8f4ee;
    border-color: #e8d6c5;
  }

  .kaching-tile[data-badge-style="best"] {
    border-color: #f8aaa7;
  }

  .kaching-tile__badge {
    position: absolute;
    top: -1.1rem;
    left: 1.2rem;
    font-size: 1.2rem;
    font-weight: 700;
    padding: 0.2rem 1rem;
    border-radius: 0.6rem;
    background: #e8d6c5;
    color: #0e1111;
  }

  .kaching-tile[data-badge-style="best"] .kaching-tile__badge {
    background: linear-gradient(180deg, #f8aaa7 0%, #f47671 100%);
    color: #fef6f6;
  }

  .kaching-tile__image {
    flex-shrink: 0;
    width: 6rem;
    height: 6rem;
    border-radius: 0.8rem;
    background-color: #f4f4f4;
    background-size: cover;
    background-position: center;
  }

  .kaching-tile__content {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
    min-width: 0;
  }

  .kaching-tile__title {
    font-weight: 700;
    font-size: 1.7rem;
    color: #0e1111;
  }

  .kaching-tile__subtitle {
    font-size: 1.3rem;
    color: #565858;
  }

  .kaching-tile__unavailable {
    font-size: 1.2rem;
    color: #c0392b;
    font-weight: 700;
  }

  .kaching-tile__price {
    flex-shrink: 0;
    font-weight: 700;
    font-size: 1.6rem;
    color: #0e1111;
  }

  .kaching-custom-display__gifts {
    margin-top: 1.6rem;
    background: #ffffff;
    border: 0.2rem solid #e8d6c5;
    border-radius: 1.2rem;
    overflow: hidden;
  }

  .kaching-custom-display__gifts-heading {
    margin: 0;
    padding: 0.8rem 1.2rem;
    background: #e8d6c5;
    color: #0e1111;
    font-weight: 700;
    font-size: 1.4rem;
    text-align: center;
    text-transform: uppercase;
  }

  .kaching-custom-display__gifts-list {
    display: flex;
    gap: 1.2rem;
    padding: 1.2rem;
  }

  .kaching-gift {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    text-align: center;
  }

  .kaching-gift__image {
    width: 4rem;
    height: 4rem;
    border-radius: 0.8rem;
    background-color: rgba(193, 122, 79, 0.2);
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    opacity: 0.5;
    filter: grayscale(1);
  }

  .kaching-gift--unlocked .kaching-gift__image {
    opacity: 1;
    filter: none;
  }

  .kaching-gift__title {
    font-size: 1.3rem;
    color: #0e1111;
  }

  .kaching-gift:not(.kaching-gift--unlocked) .kaching-gift__title {
    color: #a0a0a0;
  }

  .kaching-gift__lock-text {
    font-size: 1.1rem;
    color: #565858;
  }
</style>

<div
  class="kaching-custom-display-container"
  style="
    margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;
    margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;
  "
  {{ block.shopify_attributes }}
>
  <kaching-custom-display
    id="kaching-custom-display-{{ section.id }}-{{ block.id }}"
    class="kaching-custom-display"
    data-section="{{ section.id }}"
    data-capsules-per-package="{{ block.settings.capsules_per_package }}"
    data-capsules-per-day-by-size="{{ block.settings.capsules_per_day_by_size }}"
  >
    {% if block.settings.heading != blank %}
      <p class="kaching-custom-display__heading">{{ block.settings.heading }}</p>
    {% endif %}
    <div class="kaching-custom-display__tiles" data-tiles-container>
      <p class="kaching-custom-display__loading">{{ 'accessibility.loading' | t }}</p>
    </div>
    <div class="kaching-custom-display__gifts" hidden>
      {% if block.settings.gifts_heading != blank %}
        <p class="kaching-custom-display__gifts-heading">{{ block.settings.gifts_heading }}</p>
      {% endif %}
      <div class="kaching-custom-display__gifts-list" data-gifts-container></div>
    </div>
  </kaching-custom-display>
</div>

<script src="{{ 'kaching-custom-display.js' | asset_url }}" defer="defer"></script>
