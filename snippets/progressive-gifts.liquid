{% comment %}
  Renders the progressive-gifts custom element.

  Accepts:
  - block: {Object} block object (type product_progressive-gifts).
  - section: {Object} parent section object.

  Usage:
  {% render 'progressive-gifts', block: block, section: section %}
{% endcomment %}
{%- liquid
  assign valid_index = 0
-%}
{% capture gifts_json %}[{% for gift_block in block.blocks %}{% liquid
    assign gift_product = gift_block.settings.gift_product
    assign required_quantity = gift_block.settings.required_quantity
  %}{% if gift_product != blank and gift_product.available %}{% unless valid_index == 0 %},{% endunless %}{"variantId": {{ gift_product.first_available_variant.id | json }}, "requiredQuantity": {{ required_quantity | json }}, "handle": {{ gift_product.handle | json }}}{% assign valid_index = valid_index | plus: 1 %}{% endif %}{% endfor %}]{% endcapture %}

<div
  class="progressive-gifts-container"
  style="
    margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;
    margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;
  "
  {{ block.shopify_attributes }}
>
  <progressive-gifts
    id="progressive-gifts-{{ section.id }}-{{ block.id }}"
    class="progressive-gifts no-js-hidden"
    data-section="{{ section.id }}"
    data-product-handle="{{ product.handle }}"
  >
    <script type="application/json" data-progressive-gifts-config>{{ gifts_json }}</script>

    {% if block.blocks.size > 0 %}
      {% if block.settings.heading != blank %}
        <p class="progressive-gifts__heading">{{ block.settings.heading }}</p>
      {% endif %}
      <div class="progressive-gifts__list">
        {% for gift_block in block.blocks %}
          {% liquid
            assign gift_product = gift_block.settings.gift_product
            assign required_quantity = gift_block.settings.required_quantity
            assign badge_text = gift_block.settings.badge_text
          %}
          {% if gift_product != blank and gift_product.available %}
            <div
              class="progressive-gift"
              data-required-quantity="{{ required_quantity }}"
              {{ gift_block.shopify_attributes }}
            >
              {% if gift_product.featured_image %}
                <img
                  class="progressive-gift__image"
                  src="{{ gift_product.featured_image | image_url: width: 200 }}"
                  alt="{{ gift_product.title | escape }}"
                  width="auto"
                  height="auto"
                  loading="lazy"
                >
              {% endif %}
              <span class="progressive-gift__title">{{ gift_product.title }}</span>
              {% if badge_text != blank %}
                <span class="progressive-gift__badge">{{ badge_text }}</span>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </progressive-gifts>
</div>

<script src="{{ 'progressive-gifts.js' | asset_url }}" defer="defer"></script>
